<Window x:Class="JokeApp.Views.HistoryView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="JokeHub — Historial"
        Height="580" Width="700"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F10">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#7A1C1C"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#A02020"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2A1A1A"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="#1085A0"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0A6A80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#0D1B1E">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,1">
                    <GradientStop Color="#1085A0" Offset="0"/>
                    <GradientStop Color="#C4A100" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>0,0,0,1</Border.BorderThickness>
            <Grid Margin="22,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="▦" FontSize="22" Foreground="#1085A0"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Historial" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Rectangle Width="1" Fill="#2A4A50" Margin="14,12"/>
                    <TextBlock Text="Contenido generado recientemente" FontSize="12"
                               Foreground="#4A7A80" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="↻  Recargar"
                            Command="{Binding LoadHistoryCommand}"
                            Style="{StaticResource NavButtonStyle}"
                            Margin="0,0,8,0"/>
                    <Button Content="Limpiar todo"
                            Command="{Binding ClearHistoryCommand}"
                            IsEnabled="{Binding HasItems}"
                            Style="{StaticResource DangerButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Border Grid.Row="1" Margin="18" Background="#0F2226"
                CornerRadius="10" BorderBrush="#1085A0" BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" Color="#1085A0" Opacity="0.3" BlurRadius="14"/>
            </Border.Effect>

            <Grid>
                <!-- Estado vacío -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="▦" FontSize="48" Foreground="#1A3A40"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="El historial está vacío"
                               Foreground="#3A6A70" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Genera un chiste o meme para comenzar"
                               Foreground="#2A4A50" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Lista de registros -->
                <ListView ItemsSource="{Binding HistoryItems}"
                          Background="Transparent"
                          BorderThickness="0"
                          Margin="8"
                          Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background"      Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Margin"          Value="0,0,0,6"/>
                            <Setter Property="Padding"         Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#112226"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#091518" CornerRadius="8"
                                    BorderBrush="#1A3A40" BorderThickness="1"
                                    Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Título y tipo -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#CCDDDF"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding ContentType}"
                                                   Foreground="#4A7A80"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- Fecha -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding GeneratedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                               Foreground="#2A5A60"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- BARRA DE ESTADO -->
        <Border Grid.Row="2" Background="#070C0D" Padding="15,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#2A5A60" FontSize="11"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Cargando..." Foreground="#2A5A60" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ProgressBar IsIndeterminate="True" Width="80" Height="3"
                                 Background="Transparent" Foreground="#1085A0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>