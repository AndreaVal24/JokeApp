<Window x:Class="JokeApp.Views.FavoritesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="JokeHub — Favoritos"
        Height="620" Width="820"
        MinHeight="450" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        Background="#0A0F10">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1085A0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0A6A80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#7A1C1C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#A02020"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2A1A1A"/>
                                <Setter Property="Foreground" Value="#555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0D1B1E">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,1">
                    <GradientStop Color="#C4A100" Offset="0"/>
                    <GradientStop Color="#1085A0" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>0,0,0,1</Border.BorderThickness>
            <Grid Margin="22,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="★" FontSize="22" Foreground="#C4A100"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Favoritos" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <Rectangle Width="1" Fill="#2A4A50" Margin="14,12"/>
                    <TextBlock Text="Contenido guardado" FontSize="12"
                               Foreground="#4A7A80" VerticalAlignment="Center"/>
                </StackPanel>

                <Button Content="↻  Recargar"
                        Command="{Binding LoadFavoritesCommand}"
                        Style="{StaticResource NavButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="18" Background="#0F2226"
                CornerRadius="10" BorderBrush="#C4A100" BorderThickness="1.5">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" Color="#C4A100" Opacity="0.3" BlurRadius="14"/>
            </Border.Effect>

            <Grid>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasItems}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="★" FontSize="48" Foreground="#2A4A50"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Aun no tienes favoritos"
                               Foreground="#3A6A70" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Guarda un chiste o meme desde la pantalla principal"
                               Foreground="#2A4A50" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <ListView ItemsSource="{Binding Favorites}"
                          Background="Transparent"
                          BorderThickness="0"
                          Margin="8"
                          Visibility="{Binding HasItems, Converter={StaticResource BoolToVisibility}}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="Padding" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#112226"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#091518" CornerRadius="8"
                                    BorderBrush="#1A3A40" BorderThickness="1"
                                    Padding="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#0B1416" CornerRadius="6"
                                            BorderBrush="#2A4A50" BorderThickness="1"
                                            Margin="0,0,12,0" ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding ImageUrl}"
                                                   Stretch="UniformToFill"
                                                   Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}"/>
                                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="✎" FontSize="28" Foreground="#2A4A50"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="Chiste" Foreground="#4A7A80"
                                                           FontSize="11" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="#CCDDDF"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Content}"
                                                   Foreground="#7FA4A8"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="72">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding DisplayType}"
                                                   Foreground="#4A7A80"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding SavedAt, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                                   Foreground="#2A5A60"
                                                   FontSize="10"
                                                   HorizontalAlignment="Right"
                                                   Margin="0,0,0,8"/>
                                        <Button Content="Eliminar"
                                                Command="{Binding DataContext.DeleteFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DangerButtonStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#070C0D" Padding="15,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#2A5A60" FontSize="11"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Cargando..." Foreground="#2A5A60" FontSize="11"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ProgressBar IsIndeterminate="True" Width="80" Height="3"
                                 Background="Transparent" Foreground="#1085A0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
